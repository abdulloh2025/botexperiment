                jami = 0
                for n in klasterlar[i]:
                    jami = jami + n[d]
                yangi_markaz.append(jami / len(klasterlar[i]))
            yangi_markazlar_ruyxati.append(yangi_markaz)
        else:
            yangi_markazlar_ruyxati.append(markazlar[i])


    if yangi_markazlar_ruyxati == markazlar:
        break

    markazlar = yangi_markazlar_ruyxati


print(f"\nSikl {qadam} qadamda to'xtadi.")
