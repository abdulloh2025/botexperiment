import numpy as np  # Tasodifiy sonlar generatori uchun kerak
import matplotlib.pyplot as plt  # Grafik chizish uchun kerak

# 1. Kottaroq Dataset yaratish
# Biz taxminan y = 2x + 1 chizig'iga yaqin nuqtalar yaratamiz (bir oz shovqin bilan)
np.random.seed(42)  # Har safar bir xil natija chiqishi uchun
X_train = np.random.rand(100, 1)  # 100 ta 0 va 1 oralig'idagi tasodifiy son (x lar)
y_train = 2 * X_train + 1 + (np.random.randn(100, 1) * 0.1)  # y = 2x + 1 ga shovqin qo'shildi

# Bizning "organish_tezligi", "iteratsiya" va boshqa o'zgaruvchilarni massivga moslashtiramiz
n = len(X_train)  # Nuqtalar soni (100)

# Parametrlar
w = 0.0
b = 0.0
organish_tezligi = 0.01  # Bu kottaroq dataset uchun normal tezlik
iteratsiya_soni = 1000

# Grafik uchun ma'lumotlarni saqlash (MSE pasayishini ko'rish uchun)
mse_tarixi = []

# --- ASOSIY GRADIENT DESCENT TSIKLI (TO'G'IRLANGAN INDENTATSIYA) ---
for qadam in range(iteratsiya_soni):
    mse_yigindisi = 0.0
    grad_w_yigindisi = 0.0
    grad_b_yigindisi = 0.0

    # Har bir nuqta bo'yicha hisoblash
    for i in range(n):
        x = X_train[i][0]  # [0] chunki numpy massivi 2-o'lchamli
        y = y_train[i][0]

        # Bashorat (y = wx + b)
        y_bashorat = w * x + b

        # Xatolik
        xatolik = y - y_bashorat

        # MSE yig'indisi
        mse_yigindisi += xatolik ** 2

        # Gradientlar (Hususiy hosilalar)
        # Sizning kodingizdagi formulalar (to'g'ri): -2 * x * xatolik va -2 * xatolik
        grad_w_yigindisi += -2 * x * xatolik
        grad_b_yigindisi += -2 * xatolik

    # O'rtacha qiymatlarni hisoblash
    mse = mse_yigindisi / n
    grad_w = grad_w_yigindisi / n
    grad_b = grad_b_yigindisi / n

    # Parametrlarni yangilash (Gradient Descent qoidasi)
    w = w - organish_tezligi * grad_w
    b = b - organish_tezligi * grad_b

    # Tarixga saqlash (grafik uchun)
    mse_tarixi.append(mse)

    # Har 100 qadamda natijani chiqarish
    if qadam % 100 == 0:
        print(f"Qadam {qadam:4}: w = {w:.4f}, b = {b:.4f}, MSE = {mse:.4f}")

# Yakuniy natija
print("-" * 30)
print("O'qitish yakunlandi!")
print(f"Bashorat qilingan chiziq: y = {w:.4f}x + {b:.4f}")
print(f"Haqiqiy chiziq:      y = 2.0x + 1.0 (taxminan)")

# --- GRAFIKLAR ---

# 1-grafik: Data nuqtalari va o'qitilgan chiziq
plt.figure(figsize=(12, 5))

plt.subplot(1, 2, 1)  # Ikki grafikdan birinchisi
plt.scatter(X_train, y_train, color='blue', label='Data nuqtalari', alpha=0.6)  # Nuqtalar

# Bashorat qilingan chiziqni chizish
X_line = np.linspace(0, 1, 10)  # Chiziq uchun x qiymatlar
Y_line = w * X_line + b  # Chiziq uchun y qiymatlar
plt.plot(X_line, Y_line, color='red', linewidth=3, label=f'Bashorat: y={w:.2f}x+{b:.2f}')

plt.title('Chiziqli Regressiya Natijasi')
plt.xlabel('X (Kirish)')
plt.ylabel('Y (Chiqish)')
plt.legend()
plt.grid(True)

# 2-grafik: MSE (O'rtacha kvadratik xatolik) pasayishi
plt.subplot(1, 2, 2)  # Ikki grafikdan ikkinchisi
plt.plot(mse_tarixi, color='purple', linewidth=2)
plt.title('Xatolikning (MSE) Pasayishi')
plt.xlabel('Iteratsiya Qadami')
plt.ylabel('MSE Qiymati')
plt.grid(True)

plt.tight_layout()
plt.show()  # Grafikni ko'rsatish